# Ignore everything by default, whitelist project files
*

# ── Root files ──
!.gitignore
!README.md
!PROJECT.md
!kicad_pipeline.py
!demo_loader.py

# ── StateVarOsc design docs, models, tests ──
!StateVarOsc/
!StateVarOsc/**

# ── ADuCM362 oscillator firmware ──
!firmware/
!firmware/oscillator/
!firmware/oscillator/**

# ── Simulation work: schematics, PDFs, result plots ──
!sim_work/
!sim_work/*.kicad_sch
!sim_work/*.pdf
!sim_work/*.png
!sim_work/*.cir
!sim_work/*_results.txt
!sim_work/*_pdf/
!sim_work/*_pdf/*.pdf

# Exclude archive (old test/debug files)
sim_work/archive/

# ── SimGUI (full app needed for oscillator project) ──
!SimGUI/
!SimGUI/**

# Exclude SimGUI build artifacts
SimGUI/**/bin/
SimGUI/**/obj/
SimGUI/**/.vs/
*.csproj.user

# ── General excludes ──
*.pyc
__pycache__/
*.raw
*.log

* ---- Mux Enable Signals (sequential, non-overlapping) ----
V_EN1 EN1 0 PULSE(0 5 0.0 1u 1u 0.2 4.25)
V_EN2 EN2 0 PULSE(0 5 0.2 1u 1u 0.2 4.25)
V_EN3 EN3 0 PULSE(0 5 0.4 1u 1u 0.2 4.25)
V_EN4 EN4 0 PULSE(0 5 0.6000000000000001 1u 1u 0.2 4.25)
V_EN5 EN5 0 PULSE(0 5 0.8 1u 1u 0.2 4.25)
V_EN6 EN6 0 PULSE(0 5 1.0 1u 1u 0.2 4.25)
V_EN7 EN7 0 PULSE(0 5 1.2000000000000002 1u 1u 0.2 4.25)
V_EN8 EN8 0 PULSE(0 5 1.4000000000000001 1u 1u 0.2 4.25)
V_EN9 EN9 0 PULSE(0 5 1.6 1u 1u 0.2 4.25)
V_EN10 EN10 0 PULSE(0 5 1.8 1u 1u 0.2 4.25)
V_EN11 EN11 0 PULSE(0 5 2.0 1u 1u 0.2 4.25)
V_EN12 EN12 0 PULSE(0 5 2.2 1u 1u 0.2 4.25)
V_EN13 EN13 0 PULSE(0 5 2.4000000000000004 1u 1u 0.2 4.25)
V_EN14 EN14 0 PULSE(0 5 2.6 1u 1u 0.2 4.25)
V_EN15 EN15 0 PULSE(0 5 2.8000000000000003 1u 1u 0.2 4.25)
V_EN16 EN16 0 PULSE(0 5 3.0 1u 1u 0.2 4.25)

* ---- TIA ----
XU1 0 INV VCC VEE TIA_OUT LMC6001_NS

* ---- Feedback Network (Range 8) ----
Rf INV TIA_OUT 10G
Cf INV TIA_OUT 1p

* ---- Mux to TIA connection ----
R_WIRE TIA_IN INV 1
* Bias path prevents TIA_IN float during mux transitions
* R_BIAS scaled per range to minimize noise gain: 1 + Rf/R_BIAS
R_BIAS TIA_IN 0 100G

* ---- ADC Load ----
RL TIA_OUT AIN0 100
R_ADC AIN0 0 10Meg

* ---- Precision options for high-impedance ranges ----
.options gmin=1e-16
.options abstol=1e-16
.options reltol=1e-5

* ---- Analysis ----
.tran 10u 3.25

.control
run
wrdata C:/Users/bob43/Downloads/state variable Osc/State-Variable-Oscillator-MDAC/sim_work/channel_switching_range8_results.txt V(CH1_IN) V(CH2_IN) V(CH3_IN) V(CH4_IN) V(CH5_IN) V(CH6_IN) V(CH7_IN) V(CH8_IN) V(CH9_IN) V(CH10_IN) V(CH11_IN) V(CH12_IN) V(CH13_IN) V(CH14_IN) V(CH15_IN) V(CH16_IN) V(TIA_OUT) V(AIN0)
quit
.endc


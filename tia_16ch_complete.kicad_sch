  (text "J1 INPUT_32PIN\nTriax: center=signal, guard=driven, shield=GND\nOdd pins = CH_IN_1..16, Even pins = GND"
    (exclude_from_sim no)
    (at 50 245 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000001")
  )
  (text "INPUT FILTER BLOCK A (Channels 1-8)\nPer channel: BAV199 ESD + 1M series R + 10nF C0G\nfc = 1/(2*pi*1M*10nF) = 15.9 Hz LPF"
    (exclude_from_sim no)
    (at 183 170 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000002")
  )
  (text "INPUT FILTER BLOCK B (Channels 9-16)\nPer channel: BAV199 ESD + 1M series R + 10nF C0G\nfc = 1/(2*pi*1M*10nF) = 15.9 Hz LPF"
    (exclude_from_sim no)
    (at 183 420 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000003")
  )
  (text "16:1 channel select via ADDR[A0:A2] + EN_A/EN_B\nOnly one mux active at a time"
    (exclude_from_sim no)
    (at 383 162 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000004")
  )
  (text "U3: ADA4530-1 (20fA bias current)\nRf/Cf relay-selectable feedback\nVREF = VCC/2 = 1.65V\nR18=100k, R19=100k, C20=100nF divider\nOutput: AIN0 (TIA) + AIN1 (VREF monitor)"
    (exclude_from_sim no)
    (at 563 290 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000005")
  )
  (text "RELAY RANGE LADDER\nK1/SW1: Rf=10M  (120nA FS) - RELAY_0\nK2/SW2: Rf=100M (12nA FS)  - RELAY_1\nK3/SW3: Rf=1G + Cf=10pF (1.2nA FS) - RELAY_2\nK4/SW4: Rf=10G + Cf=1pF (120pA FS) - RELAY_3\n4x 109P-1-A-5/1 SPST reed relays\nOnly one relay closed at a time"
    (exclude_from_sim no)
    (at 563 472 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000006")
  )
  (text "RELAY DRIVERS\nQ1-Q4: 2N3904 NPN, R25-R28=1k base resistors\nD33-D36: 1N4148 flyback diodes\nR32-R35: 500 ohm relay coil resistance\nRb=1k: Ic/hFE = 5V/0.05A/100 = 0.5mA\n1k gives 3.3mA base drive"
    (exclude_from_sim no)
    (at 563 625 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000007")
  )
  (text "ADuCM362 MCU (U5)\nARM Cortex-M3, dual 24-bit sigma-delta ADC\nCN-0359 reference design\nADC0 reads TIA output (AIN0) vs reference (AIN1)\nGPIO P0 controls mux address + enables\nGPIO P1 drives relay coils via NPN drivers\nDecoupling: C1=100nF, C2=10uF (AVDD)\nC3=100nF, C4=10uF (DVDD)\nC5=470nF, C6=470nF (REG)\nC7=100nF (VREF)"
    (exclude_from_sim no)
    (at 758 255 0)
    (effects (font (size 1.524 1.524)) (justify left))
    (uuid "a0000001-0001-0001-0001-000000000008")
  )

